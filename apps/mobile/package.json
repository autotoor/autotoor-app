{
  "private": true,
  "name": "@autotoor/app-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf build",
    "dev": "expo start",
    "dev:client": "APP_VARIANT=development expo start --dev-client --host lan",
    "dev:client:local": "APP_VARIANT=development EXPO_PUBLIC_AUTOTOOR_API_BASE_URL=http://192.168.68.68:3333 expo start --dev-client --host lan",
    "lint": "eslint --ext js,ts,tsx .",
    "build": "expo export --output-dir ./build --platform all",
    "start": "expo start",
    "test": "jest",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas-build-pre-install": "npm install --global pnpm@10.4.1",
    "eas-build-post-install": "pnpm run -w build:mobile"
  },
  "dependencies": {
    "@autotoor/tour-common": "workspace:*",
    "@autotoor/ui-common": "workspace:*",
    "axios": "^1.4.0",
    "expo": "^55.0.19",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.30",
    "expo-location": "~55.1.8",
    "expo-speech": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "geodist": "^0.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-get-random-values": "^1.9.0",
    "react-native-web": "~0.21.2"
  },
  "devDependencies": {
    "@autotoor/eslint-config": "workspace:*",
    "@babel/core": "^7.19.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "babel-preset-expo": "~55.0.19",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "metro-cache": "0.83.7",
    "react-test-renderer": "19.2.0",
    "ts-mockito": "^2.6.1"
  },
  "eslintConfig": {
    "extends": "@autotoor/eslint-config",
    "ignorePatterns": [
      "node_modules",
      "build",
      ".expo",
      ".expo-shared"
    ],
    "overrides": [
      {
        "files": [
          "*.js"
        ],
        "env": {
          "node": true
        }
      }
    ]
  },
  "jest": {
    "preset": "jest-expo"
  }
}
