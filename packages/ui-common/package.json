{
  "private": true,
  "name": "@autotoor/ui-common",
  "version": "1.0.0",
  "description": "Autotoor shared UI components",
  "author": "Alex Levine",
  "license": "MIT",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "react-native": "./src/index.ts",
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf build",
    "dev": "tsup --watch --silent",
    "lint": "eslint --ext js,ts,tsx .",
    "test": "jest",
    "build": "tsup --clean"
  },
  "devDependencies": {
    "@autotoor/eslint-config": "workspace:*",
    "@testing-library/react-native": "^13.3.3",
    "@tsconfig/recommended": "^1.0.1",
    "@types/jest": "^26.0.24",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.19",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "~0.21.2",
    "react-test-renderer": "19.2.0",
    "tsup": "^6.5.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-web": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-web": {
      "optional": true
    }
  },
  "eslintConfig": {
    "extends": "@autotoor/eslint-config",
    "ignorePatterns": [
      "node_modules",
      "build"
    ]
  },
  "jest": {
    "preset": "jest-expo"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "outDir": "build",
    "sourcemap": true,
    "dts": true,
    "external": [
      "react",
      "react-native",
      "react-native-web"
    ]
  }
}
